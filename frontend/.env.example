# Frontend Environment Variables
# Backend API URL - MUST use http:// for local development
VITE_API_BASE_URL=http://grainlify-api-v1.eba-nxppxmta.us-west-2.elasticbeanstalk.com
# Frontend Base URL (optional)
VITE_FRONTEND_BASE_URL=http://localhost:5173

# DEV-ONLY: bypass sign-in and load /dashboard as a mock contributor.
# Only takes effect with `vite dev`; it is stripped from production builds.
# Default: false. Set to true locally to work on authenticated UI.
VITE_AUTH_BYPASS=false